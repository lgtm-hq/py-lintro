include LICENSE
include README.md
include pyproject.toml

# Include assets directory and its contents
recursive-include assets *
recursive-include lintro/ascii-art *
recursive-include lintro/tools *.json
recursive-include lintro/ai/prompts/templates *.md *.json

# Include any additional documentation
recursive-include docs *.md

# Include test files for development
recursive-include tests *.py
recursive-include test_samples *.py
recursive-include test_samples *.yml
recursive-include test_samples *.js
recursive-include test_samples *.sh
recursive-include test_samples *.ts
recursive-include test_samples *.toml
recursive-include test_samples *.txt
recursive-include test_samples *.css
recursive-include test_samples *.scss
recursive-include test_samples *.env
recursive-include test_samples *.sql
recursive-include test_samples *.md
recursive-include test_samples *.json
recursive-include test_samples *.diff
recursive-include test_samples *.astro
recursive-include test_samples *.vue
recursive-include test_samples *.svelte
recursive-include test_samples *.rs
recursive-include test_samples *.lock
recursive-include test_samples *.ini
recursive-include test_samples Dockerfile.*
