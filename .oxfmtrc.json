{
  "$schema": "https://raw.githubusercontent.com/oxc-project/oxc/main/npm/oxfmt/configuration_schema.json",
  "semi": true,
  "singleQuote": true,
  "tabWidth": 2,
  "printWidth": 100,
  "trailingComma": "es5",
  "sortPackageJson": false,
  "ignorePatterns": ["build", "dist", "node_modules", ".venv", ".lintro"]
}
