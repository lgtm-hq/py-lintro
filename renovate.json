      "datasourceTemplate": "crate",
      "packageNameTemplate": "cargo-audit"
    },
    {
      "description": "Update cargo-deny in _tool_versions.py and manifest.json",
      "customType": "regex",
      "managerFilePatterns": [
        "lintro/_tool_versions\\.py",
