      ],
      "datasourceTemplate": "github-releases",
      "packageNameTemplate": "mvdan/sh",
      "extractVersionTemplate": "^v(?<version>.*)$"
    },
    {
      "description": "Update taplo in _tool_versions.py and manifest.json (CLI releases use plain semver tags)",
      "customType": "regex",
      "managerFilePatterns": [
        "lintro/_tool_versions\\.py",
        "lintro/tools/manifest\\.json"
      ],
      "matchStrings": [
        "ToolName\\.TAPLO:\\s*\"(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)\"",
        "\"name\":\\s*\"taplo\",\\s*\"version\":\\s*\"(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)\""
      ],
      "datasourceTemplate": "github-releases",
      "packageNameTemplate": "tamasfe/taplo",
      "extractVersionTemplate": "^(?<version>[0-9]+\\.[0-9]+\\.[0-9]+)$"
    },
    {
      "description": "Update cargo-audit in _tool_versions.py and manifest.json",
      "customType": "regex",
      "managerFilePatterns": [
        "lintro/_tool_versions\\.py",
