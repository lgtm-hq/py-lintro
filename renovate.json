    {
      "description": "Update npm tool versions in manifest.json",
      "customType": "regex",
      "managerFilePatterns": [
        "lintro/tools/manifest\\.json"
      ],
      "matchStrings": [
        "\"name\":\\s*\"[^\"]+\",\\s*\"version\":\\s*\"(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)\",\\s*\"install\":\\s*\\{\\s*\"type\":\\s*\"npm\",\\s*\"package\":\\s*\"(?<depName>[^\"]+)\""
      ],
      "datasourceTemplate": "npm"
    },
    {
      "description": "Update pip tool versions in manifest.json",
      "customType": "regex",
      "managerFilePatterns": [
        "lintro/tools/manifest\\.json"
      ],
      "matchStrings": [
        "\"name\":\\s*\"[^\"]+\",\\s*\"version\":\\s*\"(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)\",\\s*\"install\":\\s*\\{\\s*\"type\":\\s*\"pip\",\\s*\"package\":\\s*\"(?<depName>[^\"]+)\""
