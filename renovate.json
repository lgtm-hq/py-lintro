{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "local>lgtm-hq/.github:renovate-config"
  ],
  "packageRules": [
    {
      "matchDatasources": ["docker"],
      "matchUpdateTypes": ["digest", "patch"],
      "automerge": true,
      "automergeType": "branch"
    },
    {
      "matchDatasources": ["pypi"],
      "matchUpdateTypes": ["minor"],
      "automerge": false
    },
    {
      "matchDatasources": ["pypi"],
      "matchPackageNames": ["click"],
      "allowedVersions": "<8.2",
      "automerge": false,
      "labels": ["blocked-by-psr"]
    },
    {
      "groupName": "click + psr",
      "matchDatasources": ["pypi"],
      "matchPackageNames": [
        "click",
        "python-semantic-release"
      ],
      "automerge": false
    },
    {
      "groupName": "pytest packages",
      "groupSlug": "pytest",
      "matchPackageNames": ["/^pytest/"]
    },
    {
      "matchManagers": [
        "pep621",
        "pip_requirements",
        "pip_setup",
        "pipenv",
        "poetry",
        "setup-cfg",
        "setup-py",
        "uv"
      ],
      "matchPackageNames": ["python"],
      "rangeStrategy": "widen"
    },
    {
      "description": "Bump pyproject.toml floors for bundled Python tools so uv.lock stays in sync with manifest pins",
      "groupName": "bundled python tools",
      "matchDatasources": ["pypi"],
      "matchPackageNames": [
        "ruff",
        "mypy",
        "bandit",
        "black",
        "semgrep",
        "sqlfluff",
        "pydoclint"
      ],
      "rangeStrategy": "bump"
    },
    {
      "groupName": "linting tools",
      "groupSlug": "linting-tools",
      "matchPackageNames": [
        "hadolint",
        "hadolint/hadolint",
        "actionlint",
        "rhysd/actionlint",
        "prettier",
        "markdownlint-cli2",
        "oxlint",
        "oxfmt",
        "gitleaks",
        "gitleaks/gitleaks",
        "shellcheck",
        "koalaman/shellcheck",
        "shfmt",
        "mvdan/sh",
        "taplo",
        "tamasfe/taplo",
        "astro",
        "@astrojs/check",
        "svelte-check",
        "vue-tsc"
      ],
      "automerge": false
    }
  ],
  "pip_requirements": {
    "managerFilePatterns": [
      "/^requirements.*\\.txt$/"
    ]
  },
  "lockFileMaintenance": {
    "schedule": ["before 5am on monday"],
    "commitMessageAction": "update lockfile"
  },
  "customManagers": [
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github/workflows/test-and-coverage\\.yml$/"
      ],
      "matchStrings": [
        "CODECOV_VERSION:\\s*(?<currentValue>v[0-9]+\\.[0-9]+\\.[0-9]+)"
      ],
      "datasourceTemplate": "github-releases",
      "packageNameTemplate": "codecov/uploader"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["Dockerfile"],
      "matchStrings": [
        "ARG HADOLINT_VERSION=(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)"
      ],
      "datasourceTemplate": "github-releases",
      "packageNameTemplate": "hadolint/hadolint",
      "extractVersionTemplate": "^v(?<version>.*)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": ["Dockerfile"],
      "matchStrings": [
        "ARG ACTIONLINT_VERSION=(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)"
      ],
      "datasourceTemplate": "github-releases",
      "packageNameTemplate": "rhysd/actionlint",
      "extractVersionTemplate": "^v(?<version>.*)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "Dockerfile\\.tools"
      ],
      "matchStrings": [
        "ARG BUN_VERSION=(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)"
      ],
      "datasourceTemplate": "github-releases",
      "packageNameTemplate": "oven-sh/bun",
      "extractVersionTemplate": "^bun-v(?<version>.*)$"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "Dockerfile\\.base",
        "Dockerfile\\.tools"
      ],
      "matchStrings": [
        "ARG UV_VERSION=(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)"
      ],
      "datasourceTemplate": "github-releases",
      "packageNameTemplate": "astral-sh/uv"
    },
    {
      "customType": "regex",
      "managerFilePatterns": [
        "/^\\.github/workflows/reusable-sbom\\.yml$/",
        "scripts/ci/deployment/sbom-install-binary-gh\\.sh"
      ],
      "matchStrings": [
        "BOMCTL_VERSION[=:]\\s*v(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)"
      ],
      "datasourceTemplate": "github-releases",
      "packageNameTemplate": "bomctl/bomctl",
      "extractVersionTemplate": "^v(?<version>.*)$"
    },

    {
      "description": "Update actionlint in _tool_versions.py and manifest.json",
      "customType": "regex",
      "managerFilePatterns": [
        "lintro/_tool_versions\\.py",
        "lintro/tools/manifest\\.json"
      ],
      "matchStrings": [
        "ToolName\\.ACTIONLINT:\\s*\"(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)\"",
        "\"name\":\\s*\"actionlint\",\\s*\"version\":\\s*\"(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)\""
      ],
      "datasourceTemplate": "github-releases",
      "packageNameTemplate": "rhysd/actionlint",
      "extractVersionTemplate": "^v(?<version>.*)$"
    },
    {
      "description": "Update gitleaks in _tool_versions.py and manifest.json",
      "customType": "regex",
      "managerFilePatterns": [
        "lintro/_tool_versions\\.py",
        "lintro/tools/manifest\\.json"
      ],
      "matchStrings": [
        "ToolName\\.GITLEAKS:\\s*\"(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)\"",
        "\"name\":\\s*\"gitleaks\",\\s*\"version\":\\s*\"(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)\""
      ],
      "datasourceTemplate": "github-releases",
      "packageNameTemplate": "gitleaks/gitleaks",
      "extractVersionTemplate": "^v(?<version>.*)$"
    },
    {
      "description": "Update hadolint in _tool_versions.py and manifest.json",
      "customType": "regex",
      "managerFilePatterns": [
        "lintro/_tool_versions\\.py",
        "lintro/tools/manifest\\.json"
      ],
      "matchStrings": [
        "ToolName\\.HADOLINT:\\s*\"(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)\"",
        "\"name\":\\s*\"hadolint\",\\s*\"version\":\\s*\"(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)\""
      ],
      "datasourceTemplate": "github-releases",
      "packageNameTemplate": "hadolint/hadolint",
      "extractVersionTemplate": "^v(?<version>.*)$"
