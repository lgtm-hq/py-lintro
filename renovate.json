      "customType": "regex",
      "managerFilePatterns": [
        "lintro/_tool_versions\\.py"
      ],
      "matchStrings": [
        "ToolName\\.ASTRO_CHECK:\\s*\"(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)\""
      ],
      "datasourceTemplate": "npm",
      "packageNameTemplate": "astro"
    },
    {
      "description": "Update @astrojs/check companion version in _tool_versions.py",
      "customType": "regex",
      "managerFilePatterns": [
        "lintro/_tool_versions\\.py"
      ],
      "matchStrings": [
        "\"@astrojs/check\":\\s*\"(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)\""
      ],
      "datasourceTemplate": "npm",
      "packageNameTemplate": "@astrojs/check"
    },
    {
      "description": "Update svelte-check fallback version in _tool_versions.py",
