      "matchStrings": [
        "ToolName\\.CLIPPY:\\s*\"(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)\"",
        "\"name\":\\s*\"clippy\",\\s*\"version\":\\s*\"(?<currentValue>[0-9]+\\.[0-9]+\\.[0-9]+)\""
      ],
      "datasourceTemplate": "github-tags",
      "packageNameTemplate": "rust-lang/rust-clippy",
      "extractVersionTemplate": "^rust-(?<version>.*)$"
    },
    {
      "description": "Update rustfmt in _tool_versions.py and manifest.json",
