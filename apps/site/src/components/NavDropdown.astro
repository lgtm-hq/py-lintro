---
interface Props {
  label: string;
  href: string;
  groups: import("../data/docs-nav").NavDropdownGroup[];
}

const { label, href, groups } = Astro.props;
const menuId = `nav-menu-${label.toLowerCase().replace(/\s+/g, "-")}`;
---

<div class="nav-dropdown" data-nav-dropdown>
  <a href={href} class="nav-link nav-dropdown-trigger">
    {label}
    <svg class="nav-dropdown-chevron" width="12" height="12" viewBox="0 0 12 12" aria-hidden="true">
      <path d="M2.5 4.5 6 8l3.5-3.5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" />
    </svg>
  </a>
  {
    groups.length > 0 && (
      <div class="nav-dropdown-panel" id={menuId} role="navigation" aria-label={`${label} pages`}>
        <div class="nav-dropdown-panel-inner">
          {
            groups.map((group) => (
              <div class="nav-dropdown-group">
                <p class="nav-dropdown-group-label">{group.label}</p>
                {
                  group.items.map((item) => (
                    <a href={item.href} class="nav-dropdown-item">
                      {item.label}
                    </a>
                  ))
                }
              </div>
            ))
          }
        </div>
      </div>
    )
  }
</div>

<script>
  const CLOSE_DELAY_MS = 220;
  const closeTimers = new WeakMap<HTMLElement, ReturnType<typeof setTimeout>>();

  function clearCloseTimer(dropdown: HTMLElement): void {
    const timer = closeTimers.get(dropdown);
    if (timer !== undefined) {
      clearTimeout(timer);
      closeTimers.delete(dropdown);
    }
  }

  function closeDropdown(dropdown: HTMLElement): void {
    clearCloseTimer(dropdown);
    dropdown.classList.remove("is-open");
  }

  function closeOtherDropdowns(active: HTMLElement): void {
    for (const dropdown of document.querySelectorAll<HTMLElement>("[data-nav-dropdown]")) {
      if (dropdown !== active) closeDropdown(dropdown);
    }
  }

  function initNavDropdowns(): void {
    for (const dropdown of document.querySelectorAll<HTMLElement>("[data-nav-dropdown]")) {
      if (dropdown.dataset.navBound === "true") continue;
      dropdown.dataset.navBound = "true";

      const open = (): void => {
        closeOtherDropdowns(dropdown);
        clearCloseTimer(dropdown);
        dropdown.classList.add("is-open");
      };

      const scheduleClose = (): void => {
        clearCloseTimer(dropdown);
        closeTimers.set(
          dropdown,
          setTimeout(() => {
            dropdown.classList.remove("is-open");
            closeTimers.delete(dropdown);
          }, CLOSE_DELAY_MS),
        );
      };

      dropdown.addEventListener("mouseenter", open);
      dropdown.addEventListener("mouseleave", scheduleClose);
      dropdown.addEventListener("focusin", open);
      dropdown.addEventListener("focusout", (event) => {
        const next = event.relatedTarget;
        if (next instanceof Node && dropdown.contains(next)) return;
        scheduleClose();
      });
    }
  }

  initNavDropdowns();
  document.addEventListener("astro:page-load", initNavDropdowns);
</script>

<style>
  .nav-dropdown {
    position: relative;
  }

  .nav-dropdown-trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.25rem;
  }

  .nav-dropdown-chevron {
    opacity: 0.65;
    transition: transform 0.15s ease;
  }

  /* Panel flush to trigger; padding-top is an invisible hover bridge */
  .nav-dropdown-panel {
    position: absolute;
    top: 100%;
    left: 0;
    z-index: 200;
    min-width: 14rem;
    max-width: 20rem;
    padding-top: 0.45rem;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-4px);
    pointer-events: none;
  }

  .nav-dropdown.is-open .nav-dropdown-panel,
  .nav-dropdown:focus-within .nav-dropdown-panel {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
    pointer-events: auto;
    transition:
      opacity 0.15s ease,
      transform 0.15s ease,
      visibility 0s;
  }

  .nav-dropdown:not(.is-open):not(:focus-within) .nav-dropdown-panel {
    transition: none;
  }

  .nav-dropdown-panel-inner {
    max-height: min(70vh, 28rem);
    overflow-y: auto;
    padding: 0.5rem;
    border-radius: var(--radius-lg);
    border: 1px solid var(--turbo-dropdown-border, var(--turbo-border-default));
    background: var(--turbo-dropdown-bg, var(--turbo-bg-surface));
    box-shadow: var(--shadow-md, var(--rust-warm-shadow));
  }

  .nav-dropdown.is-open .nav-dropdown-trigger,
  .nav-dropdown:focus-within .nav-dropdown-trigger {
    color: var(--site-accent, var(--rust-forge));
    background: var(--turbo-dropdown-item-hover, var(--turbo-bg-overlay));
  }

  .nav-dropdown.is-open .nav-dropdown-chevron,
  .nav-dropdown:focus-within .nav-dropdown-chevron {
    transform: rotate(180deg);
  }

  .nav-dropdown-group + .nav-dropdown-group {
    margin-top: 0.5rem;
    padding-top: 0.5rem;
    border-top: 1px solid var(--turbo-dropdown-border, var(--turbo-border-default));
  }

  .nav-dropdown-group-label {
    margin: 0 0 0.35rem;
    padding: 0 0.5rem;
    font-family: var(--font-mono, var(--turbo-font-mono));
    font-size: 0.62rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--site-accent-light, var(--rust-brass));
  }

  .nav-dropdown-item {
    display: block;
    padding: 0.45rem 0.65rem;
    border-radius: var(--radius);
    font-size: 0.88rem;
    color: var(--turbo-body-primary, var(--turbo-text-primary));
    text-decoration: none;
    line-height: 1.35;
  }

  .nav-dropdown-item:hover {
    background: var(--turbo-dropdown-item-hover, var(--turbo-bg-overlay));
    color: var(--site-accent-light, var(--rust-brass-light));
    text-decoration: none;
  }
</style>
