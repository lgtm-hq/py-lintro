---
interface Props {
  optionId: string;
  optionName: string;
  tagline: string;
}

const { optionId, optionName, tagline } = Astro.props;
const base = import.meta.env.BASE_URL;
const gallery = `${base}design/`;
---

<header class="preview-chrome" data-pagefind-ignore>
  <a href={gallery} class="back">← All directions</a>
  <span class="badge">{optionId}</span>
  <span class="name">{optionName}</span>
  <span class="tag">{tagline}</span>
</header>

<style>
  .preview-chrome {
    position: sticky;
    top: 0;
    z-index: 9999;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5rem 1rem;
    padding: 0.6rem 1.25rem;
    font-family: system-ui, sans-serif;
    font-size: 0.8rem;
    background: rgba(0, 0, 0, 0.82);
    color: #e8e8e8;
    border-bottom: 1px solid rgba(255, 255, 255, 0.12);
    backdrop-filter: blur(8px);
  }
  .back {
    color: #7dd3fc;
    text-decoration: none;
    margin-right: auto;
  }
  .back:hover {
    text-decoration: underline;
  }
  .badge {
    font-weight: 700;
    letter-spacing: 0.06em;
    text-transform: uppercase;
    opacity: 0.7;
  }
  .name {
    font-weight: 600;
  }
  .tag {
    opacity: 0.55;
    font-size: 0.75rem;
  }
</style>
