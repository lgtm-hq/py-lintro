---
import PreviewChrome from '../../components/design/PreviewChrome.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>03 Retro Compute — Lintro design</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Atkinson+Hyperlegible:wght@400;700&family=Share+Tech+Mono&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <PreviewChrome optionId="03" optionName="Retro Compute" tagline="Turbo era IDE" />
    <div class="crt" aria-hidden="true"></div>
    <div class="page">
      <div class="window hero-window">
        <div class="titlebar">
          <span class="dots"><i></i><i></i><i></i></span>
          <span class="title">LINTRO.EXE — Code Quality Suite</span>
        </div>
        <div class="body">
          <p class="boot">C:\&gt; lintro /?</p>
          <h1>All your linters.<br />One interface.</h1>
          <p class="sub">Turbo-charged quality checks for polyglot projects. Press F1 for docs.</p>
          <div class="actions">
            <button type="button" class="win-btn primary">Run Check</button>
            <button type="button" class="win-btn">Format All</button>
          </div>
        </div>
      </div>

      <div class="window features-window">
        <div class="titlebar teal">
          <span class="title">Modules loaded</span>
        </div>
        <ul class="module-list">
          <li><span class="ok">[OK]</span> ruff.lint</li>
          <li><span class="ok">[OK]</span> prettier.fmt</li>
          <li><span class="ok">[OK]</span> yamllint.cfg</li>
          <li><span class="ok">[OK]</span> pytest.run</li>
        </ul>
      </div>

      <div class="window docs-window">
        <div class="titlebar">
          <span class="title">README.TXT — Getting Started</span>
        </div>
        <div class="doc-body">
          <aside>
            <p class="tree">[+ docs]</p>
            <p class="tree indent">getting-started</p>
            <p class="tree indent active">&gt; install</p>
            <p class="tree indent">configuration</p>
          </aside>
          <article>
            <h2>Installation</h2>
            <p>1. Install package from PyPI<br />2. Run lintro chk on project root</p>
            <pre>uv pip install lintro
lintro chk .</pre>
          </article>
        </div>
        <div class="statusbar">25 tools | 0 errors | Ready</div>
      </div>
    </div>
  </body>
</html>

<style>
  :global(*) { box-sizing: border-box; }
  body {
    margin: 0;
    background: #2b2b2b;
    color: #c0c0c0;
    font-family: 'Atkinson Hyperlegible', system-ui, sans-serif;
    min-height: 100vh;
  }
  .crt {
    position: fixed;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      rgba(0, 0, 0, 0.12) 0px,
      rgba(0, 0, 0, 0.12) 1px,
      transparent 1px,
      transparent 3px
    );
    pointer-events: none;
    z-index: 100;
  }
  .page {
    max-width: 900px;
    margin: 0 auto;
    padding: 1.5rem 1rem 3rem;
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }
  .window {
    border: 2px solid #dfdfdf;
    border-top-color: #fff;
    border-left-color: #fff;
    border-right-color: #404040;
    border-bottom-color: #404040;
    background: #c0c0c0;
    box-shadow: 4px 4px 0 #000;
  }
  .titlebar {
    background: linear-gradient(90deg, #000080, #1084d0);
    color: #fff;
    padding: 0.2rem 0.4rem;
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.8rem;
  }
  .titlebar.teal { background: linear-gradient(90deg, #008080, #00a0a0); }
  .dots { display: flex; gap: 3px; }
  .dots i {
    display: block;
    width: 10px;
    height: 10px;
    background: #c0c0c0;
    border: 1px solid #404040;
  }
  .title { flex: 1; text-align: center; }
  .hero-window .body {
    padding: 1.25rem;
    background: #000;
    color: #00ff00;
    font-family: 'Share Tech Mono', monospace;
  }
  .boot { margin: 0 0 1rem; color: #ffff00; font-size: 0.85rem; }
  h1 {
    font-family: 'Atkinson Hyperlegible', sans-serif;
    font-size: 1.75rem;
    color: #fff;
    margin: 0 0 0.75rem;
    text-shadow: 0 0 8px rgba(0, 255, 255, 0.4);
  }
  .sub { color: #a0a0a0; margin: 0 0 1.25rem; font-size: 0.9rem; }
  .actions { display: flex; gap: 0.5rem; flex-wrap: wrap; }
  .win-btn {
    font-family: 'Atkinson Hyperlegible', sans-serif;
    font-size: 0.85rem;
    padding: 0.35rem 1.25rem;
    border: 2px solid #dfdfdf;
    border-top-color: #fff;
    border-left-color: #fff;
    border-right-color: #404040;
    border-bottom-color: #404040;
    background: #c0c0c0;
    color: #000;
    cursor: default;
  }
  .win-btn.primary { font-weight: 700; }
  .win-btn:active {
    border-style: inset;
    padding: 0.4rem 1.2rem 0.3rem 1.3rem;
  }
  .module-list {
    margin: 0;
    padding: 0.75rem 1rem;
    list-style: none;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.85rem;
    background: #000;
    color: #00ff00;
  }
  .ok { color: #00ff00; }
  .doc-body {
    display: grid;
    grid-template-columns: 140px 1fr;
    background: #ffffe1;
    color: #000;
    font-size: 0.9rem;
  }
  .doc-body aside {
    padding: 0.75rem;
    border-right: 1px solid #808080;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.75rem;
    background: #f0f0f0;
  }
  .tree { margin: 0.15rem 0; }
  .indent { padding-left: 0.75rem; }
  .active { font-weight: 700; color: #000080; }
  .doc-body article { padding: 0.75rem 1rem; }
  .doc-body h2 { margin: 0 0 0.5rem; font-size: 1rem; }
  .doc-body p { margin: 0 0 0.75rem; line-height: 1.5; }
  .doc-body pre {
    margin: 0;
    padding: 0.5rem;
    background: #000;
    color: #00ff00;
    font-family: 'Share Tech Mono', monospace;
    font-size: 0.75rem;
  }
  .statusbar {
    padding: 0.2rem 0.5rem;
    font-size: 0.7rem;
    border-top: 1px solid #808080;
    background: #c0c0c0;
    font-family: 'Share Tech Mono', monospace;
  }
  @media (max-width: 640px) {
    .doc-body { grid-template-columns: 1fr; }
    .doc-body aside { border-right: none; border-bottom: 1px solid #808080; }
  }
</style>
