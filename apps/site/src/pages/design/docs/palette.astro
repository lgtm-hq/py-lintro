---
import DocsPreviewChrome from '../../../components/design/DocsPreviewChrome.astro';
import DocsNavSampleArticle from '../../../components/design/DocsNavSampleArticle.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>04 Search-First — docs nav</title>
    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600&display=swap" rel="stylesheet" />
  </head>
  <body>
    <DocsPreviewChrome optionId="04" optionName="Search-First" tagline="Jump anywhere — slim chrome" />
    <div class="shell">
      <header class="top">
        <span class="logo"><span class="logo-name">lintro</span><span class="logo-scope">@docs</span></span>
        <button class="palette" type="button" aria-label="Open command palette preview">
          <span class="kbd">⌘</span><span class="kbd">K</span>
          <span class="hint">jump to page…</span>
        </button>
        <a href="#" class="nav-toggle">≡ menu</a>
      </header>
      <div class="palette-open" role="presentation" aria-hidden="true">
        <div class="palette-box">
          <input type="text" value="conf" readonly aria-label="Palette search preview" />
          <ul>
            <li class="hit"><span class="path">usage/</span>configuration <span class="badge">active</span></li>
            <li><span class="path">contributing/</span>style-guide</li>
            <li><span class="path">tools/</span>prettier</li>
            <li><span class="path">tools/</span>ruff</li>
          </ul>
          <p class="palette-foot">↑↓ navigate · enter open · esc close</p>
        </div>
      </div>
      <div class="layout">
        <aside class="sidebar slim">
          <p class="label">// quick</p>
          <a href="#">getting-started</a>
          <a href="#" class="active">configuration</a>
          <a href="#">tool matrix</a>
          <a href="#">github-integration</a>
          <a href="#" class="ghost">all pages → ⌘K</a>
        </aside>
        <main class="main">
          <nav class="crumbs" aria-label="Breadcrumb">
            <a href="#">docs</a><span>/</span><a href="#">usage</a><span>/</span><span>configuration</span>
          </nav>
          <DocsNavSampleArticle />
        </main>
      </div>
    </div>
  </body>
</html>

<style>
  :global(*) { box-sizing: border-box; }
  body { margin: 0; background: #0d0d0d; color: #c8ffc8; font-family: 'IBM Plex Mono', monospace; font-size: 13px; }
  .top {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 0.85rem 1.25rem;
    border-bottom: 1px solid #39ff14;
  }
  .logo { font-weight: 600; }
  .logo-name { color: #39ff14; }
  .logo-scope { color: #ffb000; }
  .palette {
    margin-left: auto;
    display: flex;
    align-items: center;
    gap: 0.35rem;
    padding: 0.4rem 0.75rem;
    background: #080808;
    border: 1px solid #2a4a2a;
    color: #8fbc8f;
    font-family: inherit;
    font-size: 0.75rem;
    cursor: default;
  }
  .kbd {
    padding: 0.1rem 0.35rem;
    border: 1px solid #2a4a2a;
    background: #111;
    font-size: 0.68rem;
    color: #6b9e6b;
  }
  .hint { color: #4a6a4a; margin-left: 0.25rem; }
  .nav-toggle { color: #6b9e6b; text-decoration: none; font-size: 0.78rem; }
  .palette-open {
    position: relative;
    z-index: 10;
    padding: 1.5rem;
    background: rgba(0, 0, 0, 0.65);
    border-bottom: 1px dashed #2a4a2a;
  }
  .palette-box {
    max-width: 480px;
    margin: 0 auto;
    border: 1px solid #ff6b9e;
    background: #080808;
    box-shadow: 0 0 24px rgba(255, 107, 158, 0.15);
  }
  .palette-box input {
    width: 100%;
    padding: 0.75rem 1rem;
    border: none;
    border-bottom: 1px solid #2a4a2a;
    background: transparent;
    color: #e8ffe8;
    font-family: inherit;
    font-size: 0.9rem;
  }
  .palette-box ul { list-style: none; margin: 0; padding: 0.35rem 0; }
  .palette-box li {
    padding: 0.45rem 1rem;
    font-size: 0.8rem;
    color: #6b9e6b;
    display: flex;
    gap: 0.5rem;
    align-items: center;
  }
  .palette-box li.hit { background: #1a1a1a; color: #ff6b9e; }
  .path { color: #4a6a4a; font-size: 0.72rem; }
  .badge { margin-left: auto; font-size: 0.65rem; color: #39ff14; }
  .palette-foot {
    margin: 0;
    padding: 0.5rem 1rem;
    font-size: 0.65rem;
    color: #4a6a4a;
    border-top: 1px solid #2a4a2a;
  }
  .layout { display: grid; grid-template-columns: 160px 1fr; }
  .sidebar.slim { border-right: 1px solid #2a4a2a; padding: 1rem 0; background: #080808; }
  .label { margin: 0 1rem 0.65rem; font-size: 0.68rem; color: #4a6a4a; }
  .sidebar a {
    display: block;
    padding: 0.3rem 1rem;
    color: #6b9e6b;
    text-decoration: none;
    font-size: 0.75rem;
    text-transform: lowercase;
  }
  .sidebar a.active { color: #39ff14; }
  .sidebar a.ghost { color: #4a6a4a; margin-top: 0.75rem; font-style: italic; }
  .main { padding: 1.25rem 2rem 3rem; min-width: 0; }
  .crumbs {
    margin-bottom: 1.25rem;
    font-size: 0.72rem;
    color: #4a6a4a;
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
  }
  .crumbs a { color: #6b9e6b; text-decoration: none; }
  .crumbs a:hover { color: #39ff14; }
  .crumbs span:last-child { color: #39ff14; }
  @media (max-width: 768px) { .layout { grid-template-columns: 1fr; } .sidebar { display: none; } }
</style>
