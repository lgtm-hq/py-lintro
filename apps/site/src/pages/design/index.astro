---
const base = import.meta.env.BASE_URL;

const options = [
  {
    slug: 'terminal',
    num: '01',
    name: 'Terminal Brutalist',
    tagline: 'Raw CLI — phosphor on void',
    accent: '#39ff14',
    bg: '#0d0d0d',
  },
  {
    slug: 'blueprint',
    num: '02',
    name: 'Blueprint',
    tagline: 'Technical drawing — measured precision',
    accent: '#c87941',
    bg: '#1e3a5f',
  },
  {
    slug: 'retro',
    num: '03',
    name: 'Retro Compute',
    tagline: 'Turbo era — window chrome & CRT',
    accent: '#00ffff',
    bg: '#2b2b2b',
  },
  {
    slug: 'swiss',
    num: '04',
    name: 'Swiss Editorial',
    tagline: 'Magazine minimal — ink on paper',
    accent: '#e63946',
    bg: '#f5f3ef',
  },
  {
    slug: 'neon',
    num: '05',
    name: 'Neon Polyglot',
    tagline: 'Electric dark — language glows',
    accent: '#a78bfa',
    bg: '#0a0a0f',
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>Design directions — Lintro</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans:wght@400;600;700&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <main class="gallery">
      <p class="eyebrow">Design exploration</p>
      <h1>Pick a direction</h1>
      <p class="lead">
        Five full-page mockups for the Lintro docs site. Open each, compare side by side, then tell
        us which number (or hybrid) to implement.
      </p>
      <p class="current">
        Current production home:
        <a href={`${base}`}>terminal theme</a>
        · Docs navigation:
        <a href={`${base}design/docs/`}>5 layout options</a>
      </p>

      <ul class="grid">
        {
          options.map((o) => (
            <li>
              <a
                href={`${base}design/${o.slug}/`}
                class="card"
                style={`--card-bg:${o.bg};--card-accent:${o.accent}`}
              >
                <span class="num">{o.num}</span>
                <span class="title">{o.name}</span>
                <span class="tag">{o.tagline}</span>
                <span class="cta">Open mockup →</span>
              </a>
            </li>
          ))
        }
      </ul>
    </main>
  </body>
</html>

<style>
  :global(*) {
    box-sizing: border-box;
  }
  body {
    margin: 0;
    min-height: 100vh;
    font-family: 'IBM Plex Sans', system-ui, sans-serif;
    background: #111;
    color: #f0f0f0;
  }
  .gallery {
    max-width: 1100px;
    margin: 0 auto;
    padding: 3rem 1.5rem 4rem;
  }
  .eyebrow {
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #888;
    margin: 0 0 0.5rem;
  }
  h1 {
    font-size: clamp(2rem, 5vw, 3rem);
    font-weight: 700;
    margin: 0 0 1rem;
    letter-spacing: -0.03em;
  }
  .lead {
    max-width: 42rem;
    line-height: 1.6;
    color: #aaa;
    margin: 0 0 1rem;
  }
  .current {
    font-size: 0.9rem;
    color: #666;
    margin-bottom: 2.5rem;
  }
  .current a {
    color: #7dd3fc;
  }
  .grid {
    list-style: none;
    margin: 0;
    padding: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 1.25rem;
  }
  .card {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    padding: 1.5rem;
    border-radius: 12px;
    text-decoration: none;
    color: inherit;
    background: linear-gradient(145deg, var(--card-bg) 0%, #000 120%);
    border: 1px solid color-mix(in srgb, var(--card-accent) 35%, transparent);
    box-shadow: 0 12px 40px rgba(0, 0, 0, 0.45);
    transition:
      transform 180ms ease,
      border-color 180ms ease;
  }
  .card:hover {
    transform: translateY(-4px);
    border-color: var(--card-accent);
  }
  .num {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.12em;
    color: var(--card-accent);
  }
  .title {
    font-size: 1.25rem;
    font-weight: 600;
  }
  .tag {
    font-size: 0.85rem;
    opacity: 0.75;
    flex: 1;
  }
  .cta {
    margin-top: 0.75rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--card-accent);
  }
</style>
