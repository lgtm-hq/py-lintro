---
import PreviewChrome from '../../components/design/PreviewChrome.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>01 Terminal Brutalist — Lintro design</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Mono:wght@400;600&family=IBM+Plex+Sans:wght@400;500&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <PreviewChrome optionId="01" optionName="Terminal Brutalist" tagline="Phosphor on void" />
    <div class="page">
      <header class="nav">
        <span class="logo"><span class="logo-name">lintro</span><span class="logo-scope">@docs</span></span>
        <nav>
          <a href="#">docs</a>
          <a href="#">coverage</a>
          <a href="#">github</a>
        </nav>
      </header>

      <section class="hero">
        <p class="prompt"><span class="user">dev@repo</span>:<span class="path">~/project</span>$ lintro --help</p>
        <h1>ONE CLI.<br />MANY TOOLS.<br />ZERO CEREMONY.</h1>
        <p class="sub">
          Unified linting, formatting, and testing. Native configs. Grid output. No migration
          theatre.
        </p>
        <div class="actions">
          <a class="btn primary" href="#">$ lintro check .</a>
          <a class="btn ghost" href="#">man lintro</a>
        </div>
        <pre class="output" aria-hidden="true"><code>✓ ruff      0 issues
✓ prettier  0 issues
✓ yamllint  0 issues
────────────────────
PASS  3 tools  0 issues</code></pre>
      </section>

      <section class="features">
        <article><h2>[01]</h2><h3>unified</h3><p>One command surface for 25+ ecosystem tools.</p></article>
        <article><h2>[02]</h2><h3>native</h3><p>Respects pyproject.toml, .prettierrc, .yamllint.</p></article>
        <article><h2>[03]</h2><h3>reports</h3><p>Grid, JSON, SARIF, HTML — same run, any format.</p></article>
      </section>

      <section class="docs-preview">
        <aside>
          <p class="label">// sidebar</p>
          <ul>
            <li class="active">getting-started</li>
            <li>configuration</li>
            <li>tool-analysis/</li>
          </ul>
        </aside>
        <article>
          <h2>Getting started</h2>
          <p>Install with uv, run your first check, wire into CI.</p>
          <pre><code>uv pip install lintro
lintro chk . --output-format grid</code></pre>
        </article>
      </section>
    </div>
  </body>
</html>

<style>
  :global(*) { box-sizing: border-box; }
  body {
    margin: 0;
    background: #0d0d0d;
    color: #c8ffc8;
    font-family: 'IBM Plex Mono', ui-monospace, monospace;
    font-size: 14px;
    line-height: 1.5;
  }
  .page { max-width: 1100px; margin: 0 auto; padding: 0 1.5rem 4rem; }
  .nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.25rem 0;
    border-bottom: 1px solid #39ff14;
  }
  .logo { font-weight: 600; }
  .logo-name { color: #39ff14; }
  .logo-scope { color: #ffb000; }
  .nav a { color: #6b9e6b; text-decoration: none; margin-left: 1.5rem; text-transform: lowercase; }
  .nav a:hover { color: #39ff14; }
  .hero { padding: 3rem 0 2rem; }
  .prompt { color: #6b9e6b; margin: 0 0 1.5rem; font-size: 0.85rem; }
  .user { color: #39ff14; }
  .path { color: #7dd3fc; }
  h1 {
    font-size: clamp(1.6rem, 4vw, 2.4rem);
    font-weight: 600;
    letter-spacing: 0.04em;
    margin: 0 0 1rem;
    color: #e8ffe8;
    line-height: 1.2;
  }
  .sub { color: #8fbc8f; max-width: 36rem; margin: 0 0 1.5rem; }
  .actions { display: flex; flex-wrap: wrap; gap: 0.75rem; margin-bottom: 2rem; }
  .btn {
    display: inline-block;
    padding: 0.55rem 1rem;
    border: 1px solid #39ff14;
    text-decoration: none;
    font-size: 0.85rem;
  }
  .btn.primary { background: #39ff14; color: #0d0d0d; }
  .btn.ghost { color: #39ff14; }
  .output {
    margin: 0;
    padding: 1rem;
    border: 1px dashed #2a4a2a;
    background: #080808;
    color: #39ff14;
    font-size: 0.8rem;
    overflow-x: auto;
  }
  .features {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: #39ff14;
    border: 1px solid #39ff14;
    margin-bottom: 3rem;
  }
  .features article {
    background: #0d0d0d;
    padding: 1.25rem;
  }
  .features h2 { margin: 0; font-size: 0.7rem; color: #39ff14; opacity: 0.6; }
  .features h3 { margin: 0.25rem 0 0.5rem; text-transform: lowercase; color: #e8ffe8; }
  .features p { margin: 0; color: #8fbc8f; font-size: 0.8rem; }
  .docs-preview {
    display: grid;
    grid-template-columns: 200px 1fr;
    border: 1px solid #2a4a2a;
  }
  .docs-preview aside {
    border-right: 1px solid #2a4a2a;
    padding: 1rem;
    background: #080808;
  }
  .label { margin: 0 0 0.75rem; font-size: 0.7rem; color: #4a6a4a; }
  .docs-preview ul { list-style: none; margin: 0; padding: 0; }
  .docs-preview li {
    padding: 0.35rem 0;
    color: #6b9e6b;
    font-size: 0.8rem;
    cursor: default;
  }
  .docs-preview li.active { color: #39ff14; }
  .docs-preview li.active::before { content: '> '; }
  .docs-preview article { padding: 1.5rem; }
  .docs-preview h2 { margin: 0 0 0.75rem; font-size: 1rem; color: #e8ffe8; text-transform: lowercase; }
  .docs-preview p { margin: 0 0 1rem; color: #8fbc8f; font-size: 0.85rem; }
  .docs-preview pre {
    margin: 0;
    padding: 1rem;
    background: #080808;
    border: 1px solid #2a4a2a;
    font-size: 0.78rem;
    color: #ffb000;
  }
  @media (max-width: 768px) {
    .features { grid-template-columns: 1fr; }
    .docs-preview { grid-template-columns: 1fr; }
    .docs-preview aside { border-right: none; border-bottom: 1px solid #2a4a2a; }
  }
  @media (prefers-reduced-motion: reduce) { .btn { transition: none; } }
</style>
