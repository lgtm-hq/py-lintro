---
import PreviewChrome from '../../components/design/PreviewChrome.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>05 Neon Polyglot — Lintro design</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=DM+Sans:opsz,wght@9..40,400;9..40,500;9..40,700&family=Fira+Code:wght@400;500&family=Syne:wght@600;700;800&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <PreviewChrome optionId="05" optionName="Neon Polyglot" tagline="Language glows" />
    <div class="mesh" aria-hidden="true"></div>
    <div class="page">
      <header class="nav">
        <span class="logo">lintro</span>
        <nav>
          <a href="#">Docs</a>
          <a href="#">Coverage</a>
          <a href="#">GitHub</a>
        </nav>
      </header>

      <section class="hero">
        <div class="badges">
          <span class="badge py">Python</span>
          <span class="badge rs">Rust</span>
          <span class="badge js">JS/TS</span>
          <span class="badge yaml">YAML</span>
        </div>
        <h1>Polyglot quality,<br />single command.</h1>
        <p class="sub">
          Twenty-five linters and formatters orchestrated behind one CLI — each runtime glowing
          through the same interface.
        </p>
        <div class="actions">
          <a class="btn glow" href="#">Get started</a>
          <a class="btn glass" href="#">Browse tools</a>
        </div>
      </section>

      <section class="features">
        <article class="card" data-lang="py">
          <h3>Unified CLI</h3>
          <p>check · fmt · test — one mental model.</p>
        </article>
        <article class="card" data-lang="js">
          <h3>Native configs</h3>
          <p>No migration. Your files stay canonical.</p>
        </article>
        <article class="card" data-lang="rs">
          <h3>CI-ready</h3>
          <p>SARIF, annotations, coverage bundles.</p>
        </article>
      </section>

      <section class="docs-preview glass-panel">
        <aside>
          <p class="label">Navigate</p>
          <ul>
            <li class="active" data-lang="py">Getting started</li>
            <li data-lang="js">Configuration</li>
            <li data-lang="yaml">Tool matrix</li>
          </ul>
        </aside>
        <article>
          <h2>Getting started</h2>
          <p>Install, run, ship. Three commands to first green CI.</p>
          <pre><code>uv pip install lintro
lintro chk .
lintro tst</code></pre>
        </article>
      </section>
    </div>
  </body>
</html>

<style>
  :global(*) { box-sizing: border-box; }
  body {
    margin: 0;
    background: #0a0a0f;
    color: #e8e8f0;
    font-family: 'DM Sans', system-ui, sans-serif;
    min-height: 100vh;
  }
  .mesh {
    position: fixed;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 50% at 20% 20%, rgba(167, 139, 250, 0.15), transparent),
      radial-gradient(ellipse 60% 40% at 80% 60%, rgba(255, 107, 53, 0.12), transparent),
      radial-gradient(ellipse 50% 30% at 50% 90%, rgba(247, 223, 30, 0.08), transparent);
    pointer-events: none;
  }
  .page {
    position: relative;
    z-index: 1;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 1.5rem 4rem;
  }
  .nav {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 1.5rem 0;
  }
  .logo {
    font-family: 'Syne', sans-serif;
    font-weight: 800;
    font-size: 1.35rem;
    letter-spacing: -0.04em;
    background: linear-gradient(90deg, #a78bfa, #f472b6);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }
  .nav a {
    color: #8888a0;
    text-decoration: none;
    margin-left: 1.5rem;
    font-size: 0.9rem;
    transition: color 150ms;
  }
  .nav a:hover { color: #e8e8f0; }
  .hero { padding: 2rem 0 3rem; }
  .badges { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-bottom: 1.5rem; }
  .badge {
    font-family: 'Fira Code', monospace;
    font-size: 0.7rem;
    padding: 0.3rem 0.65rem;
    border-radius: 999px;
    border: 1px solid;
  }
  .badge.py { color: #ffd43b; border-color: #ffd43b44; background: #ffd43b11; }
  .badge.rs { color: #ff6b35; border-color: #ff6b3544; background: #ff6b3511; }
  .badge.js { color: #f7df1e; border-color: #f7df1e44; background: #f7df1e11; }
  .badge.yaml { color: #cb4b16; border-color: #cb4b1644; background: #cb4b1611; }
  h1 {
    font-family: 'Syne', sans-serif;
    font-weight: 700;
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    line-height: 1.1;
    letter-spacing: -0.03em;
    margin: 0 0 1rem;
  }
  .sub { max-width: 36rem; color: #9898b0; line-height: 1.65; margin: 0 0 2rem; }
  .actions { display: flex; flex-wrap: wrap; gap: 0.75rem; }
  .btn {
    display: inline-block;
    padding: 0.7rem 1.5rem;
    border-radius: 8px;
    text-decoration: none;
    font-weight: 600;
    font-size: 0.9rem;
  }
  .btn.glow {
    background: linear-gradient(135deg, #7c3aed, #db2777);
    color: #fff;
    box-shadow: 0 0 24px rgba(167, 139, 250, 0.45);
  }
  .btn.glass {
    background: rgba(255, 255, 255, 0.06);
    border: 1px solid rgba(255, 255, 255, 0.12);
    color: #e8e8f0;
  }
  .features {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .card {
    padding: 1.25rem;
    border-radius: 12px;
    background: rgba(255, 255, 255, 0.04);
    border: 1px solid rgba(255, 255, 255, 0.08);
    border-left-width: 3px;
  }
  .card[data-lang='py'] { border-left-color: #ffd43b; }
  .card[data-lang='js'] { border-left-color: #f7df1e; }
  .card[data-lang='rs'] { border-left-color: #ff6b35; }
  .card h3 {
    font-family: 'Syne', sans-serif;
    margin: 0 0 0.35rem;
    font-size: 1rem;
  }
  .card p { margin: 0; font-size: 0.85rem; color: #9898b0; }
  .glass-panel {
    display: grid;
    grid-template-columns: 200px 1fr;
    border-radius: 16px;
    background: rgba(255, 255, 255, 0.05);
    border: 1px solid rgba(255, 255, 255, 0.1);
    backdrop-filter: blur(12px);
    overflow: hidden;
  }
  .docs-preview aside {
    padding: 1.25rem;
    border-right: 1px solid rgba(255, 255, 255, 0.08);
  }
  .label {
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #686880;
    margin: 0 0 0.75rem;
  }
  .docs-preview ul { list-style: none; margin: 0; padding: 0; font-size: 0.9rem; }
  .docs-preview li {
    padding: 0.4rem 0.5rem;
    border-radius: 6px;
    color: #787890;
    border-left: 2px solid transparent;
    margin-bottom: 0.15rem;
  }
  .docs-preview li.active { color: #e8e8f0; background: rgba(255, 255, 255, 0.05); }
  .docs-preview li[data-lang='py'].active { border-left-color: #ffd43b; }
  .docs-preview li[data-lang='js'].active { border-left-color: #f7df1e; }
  .docs-preview li[data-lang='yaml'].active { border-left-color: #cb4b16; }
  .docs-preview article { padding: 1.5rem; }
  .docs-preview h2 {
    font-family: 'Syne', sans-serif;
    margin: 0 0 0.75rem;
    font-size: 1.35rem;
  }
  .docs-preview p { margin: 0 0 1rem; color: #9898b0; font-size: 0.95rem; }
  .docs-preview pre {
    margin: 0;
    padding: 1rem;
    border-radius: 8px;
    background: rgba(0, 0, 0, 0.4);
    font-family: 'Fira Code', monospace;
    font-size: 0.8rem;
    color: #c4b5fd;
  }
  @media (max-width: 768px) {
    .features, .glass-panel { grid-template-columns: 1fr; }
    .docs-preview aside { border-right: none; border-bottom: 1px solid rgba(255, 255, 255, 0.08); }
  }
  @media (prefers-reduced-motion: reduce) {
    .btn.glow { box-shadow: none; }
  }
</style>
