---
import PreviewChrome from '../../components/design/PreviewChrome.astro';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>04 Swiss Editorial — Lintro design</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=Geist:wght@400;500;600&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <PreviewChrome optionId="04" optionName="Swiss Editorial" tagline="Ink on paper" />
    <div class="page">
      <header class="nav">
        <a class="logo" href="#">Lintro</a>
        <nav>
          <a href="#">Documentation</a>
          <a href="#">GitHub</a>
        </nav>
      </header>

      <section class="hero">
        <div class="hero-text">
          <p class="issue">Issue 01 — Developer Tools</p>
          <h1>One interface for code quality</h1>
          <p class="sub">
            Lintro unifies linting, formatting, and testing across languages — without asking teams
            to abandon the configs they already trust.
          </p>
          <a class="cta" href="#">Read the guide</a>
        </div>
        <div class="hero-space" aria-hidden="true">
          <span class="accent-block"></span>
        </div>
      </section>

      <section class="features">
        <article>
          <span class="num">I</span>
          <h3>Unified</h3>
          <p>Twenty-five tools. One command. Consistent output.</p>
        </article>
        <article>
          <span class="num">II</span>
          <h3>Native</h3>
          <p>Your pyproject.toml and .prettierrc stay authoritative.</p>
        </article>
        <article>
          <span class="num">III</span>
          <h3>Portable</h3>
          <p>Grid for humans, SARIF for CI, JSON for machines.</p>
        </article>
      </section>

      <section class="docs-preview">
        <div class="rule" aria-hidden="true"></div>
        <aside>
          <p class="label">Contents</p>
          <ol>
            <li class="active">Getting started</li>
            <li>Configuration</li>
            <li>Tool reference</li>
          </ol>
        </aside>
        <article>
          <h2>Getting started</h2>
          <p class="dropcap">Install from PyPI, point lintro at your repository, and run your first check in under a minute.</p>
          <pre><code>uv pip install lintro
lintro check .</code></pre>
        </article>
      </section>
    </div>
  </body>
</html>

<style>
  :global(*) { box-sizing: border-box; }
  body {
    margin: 0;
    background: #f5f3ef;
    color: #111;
    font-family: 'Geist', system-ui, sans-serif;
    font-size: 16px;
    line-height: 1.6;
  }
  .page { max-width: 1100px; margin: 0 auto; padding: 0 2rem 5rem; }
  .nav {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    padding: 2rem 0 1rem;
    border-bottom: 2px solid #111;
  }
  .logo {
    font-family: 'Instrument Serif', Georgia, serif;
    font-size: 1.75rem;
    color: #111;
    text-decoration: none;
    letter-spacing: -0.02em;
  }
  .nav a:not(.logo) {
    margin-left: 2rem;
    color: #111;
    text-decoration: none;
    font-size: 0.85rem;
    letter-spacing: 0.04em;
    text-transform: uppercase;
    font-weight: 500;
  }
  .hero {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: 2rem;
    padding: 4rem 0 3rem;
    align-items: end;
  }
  .issue {
    font-size: 0.7rem;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: #e63946;
    margin: 0 0 1rem;
    font-weight: 600;
  }
  h1 {
    font-family: 'Instrument Serif', Georgia, serif;
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 400;
    line-height: 1.05;
    letter-spacing: -0.03em;
    margin: 0 0 1.25rem;
    max-width: 12ch;
  }
  .sub {
    max-width: 32rem;
    color: #444;
    margin: 0 0 2rem;
    font-size: 1.05rem;
  }
  .cta {
    display: inline-block;
    padding: 0.75rem 0;
    color: #111;
    font-weight: 600;
    text-decoration: none;
    border-bottom: 2px solid #e63946;
    letter-spacing: 0.02em;
  }
  .hero-space {
    display: flex;
    align-items: flex-end;
    justify-content: flex-end;
    min-height: 200px;
  }
  .accent-block {
    display: block;
    width: 70%;
    height: 180px;
    background: #e63946;
  }
  .features {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    padding: 3rem 0;
    border-top: 1px solid #ccc;
    border-bottom: 1px solid #ccc;
  }
  .num {
    font-family: 'Instrument Serif', serif;
    font-size: 2rem;
    color: #e63946;
    font-style: italic;
  }
  .features h3 {
    margin: 0.5rem 0 0.35rem;
    font-size: 0.8rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    font-weight: 600;
  }
  .features p { margin: 0; color: #555; font-size: 0.95rem; }
  .docs-preview {
    display: grid;
    grid-template-columns: 200px 1fr;
    gap: 3rem;
    padding-top: 3rem;
    position: relative;
  }
  .rule {
    position: absolute;
    top: 0;
    left: 200px;
    width: 2px;
    height: 100%;
    background: #111;
  }
  .label {
    font-size: 0.65rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #888;
    margin: 0 0 1rem;
  }
  .docs-preview ol {
    margin: 0;
    padding: 0 0 0 1.25rem;
    font-size: 0.9rem;
    color: #666;
  }
  .docs-preview li { padding: 0.2rem 0; }
  .docs-preview li.active { color: #111; font-weight: 600; }
  .docs-preview h2 {
    font-family: 'Instrument Serif', serif;
    font-size: 2rem;
    font-weight: 400;
    margin: 0 0 1rem;
  }
  .dropcap::first-letter {
    font-family: 'Instrument Serif', serif;
    font-size: 3.5rem;
    float: left;
    line-height: 0.85;
    margin: 0.1rem 0.5rem 0 0;
    color: #e63946;
  }
  .docs-preview p { margin: 0 0 1.5rem; color: #333; max-width: 38rem; }
  .docs-preview pre {
    margin: 0;
    padding: 1.25rem;
    background: #111;
    color: #f5f3ef;
    font-size: 0.85rem;
    overflow-x: auto;
  }
  @media (max-width: 768px) {
    .hero, .features, .docs-preview { grid-template-columns: 1fr; }
    .hero-space { display: none; }
    .rule { display: none; }
  }
</style>
