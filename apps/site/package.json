{
  "name": "@lintro/site",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "license": "MIT",
  "engines": {
    "node": ">=24.0.0"
  },
  "scripts": {
    "migrate": "python3 ../../scripts/ci/site/migrate-docs-content.py",
    "dev": "bun run migrate && astro dev",
    "build": "bun run migrate && node scripts/copy-assets.mjs && astro build && bun x pagefind --site dist --glob '**/*.html' --exclude-selectors '[data-pagefind-ignore]' --exclude-selectors 'nav' --exclude-selectors 'footer'",
    "preview": "bash ../../scripts/ci/site/preview-serve.sh",
    "test": "bun run migrate && vitest run --coverage",
    "check": "bun run migrate && astro check",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.3",
    "@lgtm-hq/turbo-themes": "^0.21.0",
    "astro": "^7.0.9",
    "sanitize-html": "^2.17.5"
  },
  "devDependencies": {
    "@astrojs/check": "0.9.9",
    "@pagefind/default-ui": "1.5.2",
    "pagefind": "1.5.2",
    "@types/sanitize-html": "2.16.1",
    "@vitest/coverage-v8": "4.1.10",
    "typescript": "6.0.3",
    "vitest": "4.1.10",
    "yaml": "2.9.0"
  },
  "overrides": {
    "yaml": "^2.9.0",
    "vite": "^8.0.16",
    "js-yaml": "^4.2.0",
    "esbuild": "^0.28.1"
  }
}
